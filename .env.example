# Supabase Configuration
# Replace these with your project values from Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Admin Panel Configuration
# The password used to access /matecito-admin/login
BLOG_ADMIN_KEY=your-secure-password

# Session Security (Required)
# Generate a long random string (e.g., using `openssl rand -base64 32`)
SESSION_SECRET=your-random-session-secret
